# --- Devin (required) ---
# Personal API key (apk_user_*) or service key (apk_*)
DEVIN_API_KEY=apk_replace_me

# --- Target repo (required) ---
# A GitHub repo you control. Devin will clone, fix, and open PRs against it.
# Ingestion watches open issues on this repo labeled `security` (configurable below).
TARGET_REPO_URL=https://github.com/your-org/your-repo

# --- GitHub (required for real PR creation) ---
# Token with repo write permissions on TARGET_REPO_URL.
# Passed to Devin as a session_secret named GITHUB_TOKEN.
GITHUB_TOKEN=ghp_replace_me

# --- Ingestion ---
# Which issue label to watch. Default: security
ISSUE_LABEL=security

# --- Webhook (optional) ---
# If set, POST /api/webhooks/github is enabled and validates HMAC-SHA256
# signatures against this secret. Leave blank to keep the endpoint disabled (503).
# Generate with:  openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# --- Optional ---
PORT=4000
# Path is resolved relative to backend/prisma/, so ../data lands the file at backend/data/app.db
DATABASE_URL=file:../data/app.db

# How many concurrent Devin sessions to keep in flight (1-10, default 2)
MAX_CONCURRENT_DEVIN_SESSIONS=2

# Cron schedule for automatic runs (5-field cron). Set CRON_ENABLED=false to disable.
CRON_ENABLED=true
CRON_SCHEDULE=*/5 * * * *

# Devin polling cadence (ms)
POLL_INTERVAL_MS=15000
